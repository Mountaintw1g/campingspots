# Lämna tom i lokal utveckling - Vite-proxyn i vite.config.ts sköter /api då.
# Sätt till Render-URL:en i produktion, t.ex. https://taltkartan-api.onrender.com
VITE_API_BASE_URL=

# Supabase project URL och anon/public key (Project Settings -> API)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxxx
